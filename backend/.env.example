# Copy this file to .env and fill values before deploying
PORT=5000
JWT_SECRET=replace_with_a_strong_secret
DB_PATH=./smallsteps.db
# Optional: set allowed origins for CORS (comma-separated). Leave empty to allow all origins (development).
ALLOWED_ORIGINS=https://your-frontend.example.com,https://another-origin.example.com

# Postgres (for migration)
# If you migrate to Postgres, set a DATABASE_URL (Postgres connection string)
# Example: postgres://user:password@hostname:5432/dbname
DATABASE_URL=postgres://user:password@hostname:5432/smallstepsdb
